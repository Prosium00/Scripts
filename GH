    local gearFrame = scrolling:FindFirstChild(gearName)
    if not gearFrame then return 0 end

    local mainInfo = gearFrame:FindFirstChild("MainInfo")
    if not mainInfo then return 0 end

    local stockLabel = mainInfo:FindFirstChild("StockText")
