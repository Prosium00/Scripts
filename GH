local function IsFruitAllowed(fruitName)
    if not selectedfruits or #selectedfruits == 0 then
        return true
    end

    for _, v in ipairs(selectedfruits) do
        if fruitName:lower():find(v:lower()) then
            return true
        end
    end

    return false
end

