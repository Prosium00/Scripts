local Toggle = fTab:Toggle({
    Title = "Auto Harvest",
    Desc = "This will only harvest selected fruit and stage",
	Flag = "AutoHarvestToggle",
    Icon = "bird",
    Type = "Checkbox",
    Value = false,

    Callback = function(state)
        getgenv().farmstage = state

        if state then
            task.spawn(function()
                while getgenv().farmstage do
                    task.wait(0.00001)

                    for _, v in ipairs(workspace.ClientPlants:GetChildren()) do
                        if v:GetAttribute("OwnerUserId") == player.UserId then

                            local ripeness = v:GetAttribute("RipenessStage")
                            local harvestable = v:GetAttribute("HarvestablePlant")

                            if harvestable == true and IsStageAllowed(ripeness) and IsFruitAllowed(v.Name) then
                                harvest:FireServer({
                                    { Uuid = v:GetAttribute("Uuid") }
                                })
                            else
                                for _, p in ipairs(v:GetChildren()) do
                                    if p.Name:find("Fruit")
                                    and IsStageAllowed(p:GetAttribute("RipenessStage")) and IsFruitAllowed(v.Name) then

                                        local uuid = p:GetAttribute("Uuid")

                                        if uuid then
                                            uuid = uuid
                                                :gsub(":regrow:.*", "")
                                                :gsub(":%d+$", "")
                                        end

                                        harvest:FireServer({
                                            {
                                                GrowthAnchorIndex = p:GetAttribute("GrowthAnchorIndex"),
                                                Uuid = uuid
                                            }
                                        })
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        end
    end
})

