local function GetSeedStock(seedName)
    local seedShop = player.PlayerGui:FindFirstChild("SeedShop")
    if not seedShop then return 0 end

    local scrolling = seedShop:FindFirstChild("Frame")
        and seedShop.Frame:FindFirstChild("ScrollingFrame")

    if not scrolling then return 0 end

    local cleanName = seedName:gsub("%s*Seed", "")

    local seedFrame = scrolling:FindFirstChild(cleanName)
    if not seedFrame then return 0 end

    local mainInfo = seedFrame:FindFirstChild("MainInfo")
    if not mainInfo then return 0 end

    local stockLabel = mainInfo:FindFirstChild("StockText")
    if not stockLabel then return 0 end

    local number = tonumber(string.match(stockLabel.Text, "%d+"))

    return number or 0
end


local Toggle = sTab:Toggle({
    Title = "Auto buy seeds",
    Desc = "Auto buy selected seeds",
    Flag = "AutoBuySeedsToggle",
    Icon = "bird",
    Type = "Checkbox",
    Value = false,

    Callback = function(state)
        getgenv().Buy = state

        if state then
            task.spawn(function()
                local char = player.Character or player.CharacterAdded:Wait()
                local hrp = char:WaitForChild("HumanoidRootPart")

                while getgenv().Buy do
                    task.wait(0.1)

                    for _, seedName in ipairs(selectedSeeds) do
                        local stock = GetSeedStock(seedName)

                        if stock > 0 then                        
                            local oldcf = hrp.CFrame
                            
                    
                            hrp.CFrame = CFrame.new(176.70,204.02,672.00)
                            task.wait(0.5)

                            repeat
                                game:GetService("ReplicatedStorage")
                                    :WaitForChild("RemoteEvents")
                                    :WaitForChild("PurchaseShopItem")
                                    :InvokeServer("SeedShop", seedName)

                                task.wait(0.1)
                                stock = GetSeedStock(seedName)

                            until stock <= 0 or not getgenv().Buy
                            if stock <= 0 and getgenv().Buy then
                                hrp.CFrame = oldcf
                            end
                        end
                    end
                end
            end)
        end
    end
})
local function GetGearStock(gearName)
